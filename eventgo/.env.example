# EventGo Environment Configuration
# Copy this file to .env and fill in actual values

# Application
APP_NAME=EventGo
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# Database (MySQL running in Docker)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=eventgo_dev
DB_NAME=eventgo

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Redis (Celery broker — configured in Module 5)
REDIS_URL=redis://localhost:6379/0

# Email (configured in Module 5)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
